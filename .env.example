# ──────────────────────────────────────────────
# TRADLINKAPI — Environment Variables
# Copy to .env and fill in real values.
# ──────────────────────────────────────────────

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (PostgreSQL)
DATABASE_URL=postgres://tradlink:password@localhost:5432/tradlinkapi

# Redis (cache + Celery broker)
REDIS_URL=redis://127.0.0.1:6379/0

# AWS / Cloudflare R2 (production only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto
AWS_S3_CUSTOM_DOMAIN=

# Email (production only)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@tradlink.co.zw

# Sentry (production only)
SENTRY_DSN=

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
